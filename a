from fastapi import FastAPI, Header, HTTPException
import uvicorn

app = FastAPI(title="Sua IA Profissional")

# Banco de dados simples para suas próprias chaves
MINHAS_CHAVES = ["SNOW-IA-PRO-2026", "ADMIN-MASTER-KEY"]

@app.get("/config")
def obter_configuracao(api_key: str = Header(None)):
    if api_key not in MINHAS_CHAVES:
        raise HTTPException(status_code=401, detail="Chave API Inválida")
    return {"status": "Online", "versao": "1.0.0", "engine": "Propria"}

@app.post("/chat")
async def chat_ia(pergunta: str, modo: str, api_key: str = Header(None)):
    """
    Modos: 'rapido' (respostas instantâneas) 
           'raciocinio' (análise profunda)
    """
    if api_key not in MINHAS_CHAVES:
        raise HTTPException(status_code=401, detail="Chave não autorizada")

    if modo == "raciocinio":
        # Aqui entra a lógica de processamento lento e perfeito
        return {"resposta": "Analisando dados em tempo real... [Processamento Profissional]", "modo": "Raciocínio"}
    
    return {"resposta": "Resposta rápida gerada!", "modo": "Rápido"}

if __name__ == "__main__":
    uvicorn.run(app, host="0.0.0.0", port=8000)
